{
  "name": "sql-seed-mvp",
  "version": "0.1.0",
  "description": "Generate deterministic fake SQL Server seed data from exported schemas.",
  "type": "module",
  "bin": {
    "sql-seed": "./src/cli.js"
  },
  "scripts": {
    "test": "node --test",
    "demo": "node ./src/cli.js --schema ./examples/five-table-schema.json --out ./out --format sql,csv --rows users=8,orders=12 --seed demo",
    "build:bin": "npx pkg . --out-path ./dist --targets node20-win-x64,node20-macos-x64,node20-linux-x64"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED"
}
